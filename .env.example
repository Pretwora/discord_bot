# ─── Discord ───────────────────────────────────────
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
LEVEL_UP_CHANNEL_ID=

# ─── Level roles ───────────────────────────────────
ROLE_РОСТОК=
ROLE_АКТИВНЫЙ=
ROLE_ВЕТЕРАН=
ROLE_ИЗБРАННЫЙ=
ROLE_ЛЕГЕНДА=

# ─── API Server ────────────────────────────────────
# PORT выставляется Railway автоматически
JWT_SECRET=
JWT_EXPIRES_IN=7d
ALLOWED_ORIGIN=https://your-dashboard.up.railway.app

# ─── Admin access ──────────────────────────────────
ADMIN_ROLE_NAME=Управление

# ─── Database (Railway Postgres — выставляется плагином автоматически) ──
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ─── Dashboard build args ──────────────────────────
VITE_API_URL=https://your-api.up.railway.app
VITE_SOCKET_URL=https://your-api.up.railway.app
