FROM node:20-slim
RUN apt-get update -y && apt-get install -y openssl && rm -rf /var/lib/apt/lists/*
WORKDIR /app
COPY package*.json ./
RUN npm ci --omit=dev
COPY . .
RUN npx prisma generate --schema=db/schema.prisma
CMD ["sh", "-c", "npx prisma migrate deploy --schema=db/schema.prisma && node api/index.js"]
